# ----- Auth -----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                        # generate: openssl rand -base64 32

# ----- Database (Supabase Postgres) -----
DATABASE_URL=postgresql://...           # from Supabase dashboard (connection pooler)
DIRECT_URL=postgresql://...            # direct connection for Prisma migrate

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=             # server-side only, never expose to client

# ----- OpenAI -----
OPENAI_API_KEY=sk-...                  # server-side only

# ----- Resend -----
RESEND_API_KEY=re_...                  # server-side only
EMAIL_FROM=noreply@yourdomain.com      # must be a verified sender in Resend

# ----- Cron -----
CRON_SECRET=                           # shared between Vercel Cron trigger and Railway worker

# ----- Feature flags -----
ENABLE_PREVIEW_EMAIL=true
