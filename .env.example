# ----- Auth -----
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=                            # generate: openssl rand -base64 32
AUTH_RESEND_KEY=re_...                  # Resend API key for magic link emails

# ----- Database (Supabase Postgres) -----
DATABASE_URL=postgresql://...           # PgBouncer URL (port 6543, for prisma migrate)
DIRECT_URL=postgresql://...            # Direct connection (port 5432, for runtime queries)

# ----- Gemini -----
GEMINI_API_KEY=                         # Google AI Studio — embedding-001 (768-dim)

# ----- Groq -----
GROQ_API_KEY=                           # Groq — llama-3.1-8b-instant (keyword expand + reasons)

# ----- Resend -----
RESEND_API_KEY=re_...                   # Resend daily digest email

# ----- Cron -----
CRON_SECRET=                            # generate: openssl rand -hex 32
