// JobPilot — Prisma Schema
// last-updated: 2026-06-10

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ─────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  image          String?
  email          String    @unique
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  locationFilter String[]  @default(["台北市", "新北市"])

  accounts         Account[]
  sessions         Session[]
  resume           Resume?
  jobIntent        JobIntent?
  recommendations  Recommendation[]
  emailLogs        EmailLog[]
  applications     Application[]
  savedJobs        SavedJob[]
  questionBank     QuestionBank[]
  workExperiences  WorkExperience[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Resume ──────────────────────────────────────────────────────────────────

model Resume {
  id              String    @id @default(cuid())
  userId          String    @unique
  storageUrl      String
  title           String?
  seniority       String?
  industry        String?
  skills          Json      @default("[]")
  yearsExperience Int?
  parsedAt        DateTime?
  updatedAt       DateTime  @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding ResumeEmbedding?
}

model ResumeEmbedding {
  resumeId  String   @id
  embedding Unsupported("vector(768)")
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

// ─── Job Intent ──────────────────────────────────────────────────────────────

model JobIntent {
  id               String   @id @default(cuid())
  userId           String   @unique
  rawInput         String
  expandedKeywords Json     @default("[]")
  updatedAt        DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding IntentEmbedding?
}

model IntentEmbedding {
  intentId  String   @id
  embedding Unsupported("vector(768)")
  updatedAt DateTime @updatedAt

  intent JobIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)
}

// ─── Job Description ─────────────────────────────────────────────────────────

model Jd {
  id                  String   @id @default(cuid())
  source              String   @default("104")
  externalUrl         String   @unique
  companyName         String
  title               String
  skills              Json     @default("[]")
  salaryRange         String?
  seniority           String?
  remote              Boolean  @default(false)
  location            String?
  recruitmentActivity String?
  replyDays           String?
  contactTime         String?
  description         String?
  postedAt            String?
  applicantCount      Int?
  locationFiltered    Boolean  @default(false)
  crawledAt           DateTime @default(now())
  parseStatus         String   @default("ok")

  embedding        JdEmbedding?
  recommendations  Recommendation[]
  emailLogs        EmailLog[]
  applications     Application[]
  savedJobs        SavedJob[]
}

model JdEmbedding {
  jdId      String @id
  embedding Unsupported("vector(768)")

  jd Jd @relation(fields: [jdId], references: [id], onDelete: Cascade)
}

// ─── Match & Email ───────────────────────────────────────────────────────────

model Recommendation {
  id            String   @id @default(cuid())
  userId        String
  jdId          String
  resumeScore   Float
  intentScore   Float
  finalScore    Float
  reasoning     String?
  alignedSkills Json     @default("[]")
  dailyBatch    DateTime

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jd        Jd         @relation(fields: [jdId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]

  @@unique([userId, jdId, dailyBatch])
}

// ─── Application Tracking ────────────────────────────────────────────────────

model Application {
  id          String   @id @default(cuid())
  userId      String
  jdId        String
  status      String   @default("not_applied")
  companyType  String?
  appliedAt    DateTime?
  scheduledAt  DateTime?
  note        String?
  aiQuestions   Json      @default("[]")
  resumeUrl     String?
  isArchived    Boolean   @default(false)
  archiveReason String?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jd               Jd                @relation(fields: [jdId], references: [id], onDelete: Cascade)
  interviewRecords InterviewRecord[]
  interviewReviews InterviewReview[]

  @@unique([userId, jdId])
}

model InterviewRecord {
  id            String   @id @default(cuid())
  applicationId String
  interviewedAt DateTime
  interviewer   String?
  qa            Json     @default("[]")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ─── Saved Jobs ──────────────────────────────────────────────────────────────

model SavedJob {
  id          String   @id @default(cuid())
  userId      String
  jdId        String?
  externalUrl String
  companyName String
  title       String
  platform    String   @default("other")
  companyType String?
  status      String   @default("watching")
  savedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jd   Jd?  @relation(fields: [jdId], references: [id])

  @@unique([userId, externalUrl])
}

// ─── Email ───────────────────────────────────────────────────────────────────

model EmailLog {
  id               String    @id @default(cuid())
  userId           String
  recommendationId String
  jdId             String
  sentAt           DateTime  @default(now())
  clickedAt        DateTime?
  trackingToken    String    @unique @default(cuid())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  jd             Jd             @relation(fields: [jdId], references: [id], onDelete: Cascade)
}

// ─── Interview Review ────────────────────────────────────────────────────────

model InterviewReview {
  id              String   @id @default(cuid())
  applicationId   String
  audioUrl        String?
  transcript      String?  @db.Text
  extractedQA     Json     @default("[]")
  overallFeedback String?  @db.Text
  createdAt       DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ─── Work Experience ─────────────────────────────────────────────────────────

model WorkExperience {
  id          String   @id @default(cuid())
  userId      String
  company     String
  role        String
  startDate   String?
  endDate     String?
  description String   @db.Text
  skills      Json     @default("[]")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Question Bank ───────────────────────────────────────────────────────────

model QuestionBank {
  id                    String   @id @default(cuid())
  userId                String
  question              String
  answer                String?  @db.Text
  category              String   @default("other")
  sourceApplicationId   String?
  userPerformance       String?
  frequency             Int      @default(1)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
