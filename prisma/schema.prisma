// JobPilot — Prisma Schema
// last-updated: 2026-05-21

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (NextAuth) ─────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  locationFilter String[]  @default(["台北市", "新北市"])

  accounts        Account[]
  sessions        Session[]
  resume          Resume?
  jobIntent       JobIntent?
  recommendations Recommendation[]
  emailLogs       EmailLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Resume ──────────────────────────────────────────────────────────────────

model Resume {
  id              String    @id @default(cuid())
  userId          String    @unique
  storageUrl      String
  title           String?
  seniority       String?
  industry        String?
  skills          Json      @default("[]")
  yearsExperience Int?
  parsedAt        DateTime?
  updatedAt       DateTime  @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding ResumeEmbedding?
}

model ResumeEmbedding {
  resumeId  String   @id
  embedding Unsupported("vector(1536)")
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

// ─── Job Intent ──────────────────────────────────────────────────────────────

model JobIntent {
  id               String   @id @default(cuid())
  userId           String   @unique
  rawInput         String
  expandedKeywords Json     @default("[]")
  updatedAt        DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding IntentEmbedding?
}

model IntentEmbedding {
  intentId  String   @id
  embedding Unsupported("vector(1536)")
  updatedAt DateTime @updatedAt

  intent JobIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)
}

// ─── Job Description ─────────────────────────────────────────────────────────

model Jd {
  id                  String   @id @default(cuid())
  source              String   @default("104")
  externalUrl         String   @unique
  companyName         String
  title               String
  skills              Json     @default("[]")
  salaryRange         String?
  seniority           String?
  remote              Boolean  @default(false)
  location            String?
  recruitmentActivity String?
  replyDays           String?
  contactTime         String?
  locationFiltered    Boolean  @default(false)
  crawledAt           DateTime @default(now())
  parseStatus         String   @default("ok")

  embedding       JdEmbedding?
  recommendations Recommendation[]
  emailLogs       EmailLog[]
}

model JdEmbedding {
  jdId      String @id
  embedding Unsupported("vector(1536)")

  jd Jd @relation(fields: [jdId], references: [id], onDelete: Cascade)
}

// ─── Match & Email ───────────────────────────────────────────────────────────

model Recommendation {
  id            String   @id @default(cuid())
  userId        String
  jdId          String
  resumeScore   Float
  intentScore   Float
  finalScore    Float
  reasoning     String?
  alignedSkills Json     @default("[]")
  dailyBatch    DateTime

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jd        Jd         @relation(fields: [jdId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]

  @@unique([userId, jdId, dailyBatch])
}

model EmailLog {
  id               String    @id @default(cuid())
  userId           String
  recommendationId String
  jdId             String
  sentAt           DateTime  @default(now())
  clickedAt        DateTime?
  trackingToken    String    @unique @default(cuid())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  jd             Jd             @relation(fields: [jdId], references: [id], onDelete: Cascade)
}
