// JobPilot — Prisma Schema
// last-updated: 2026-06-10

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ─────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  image          String?
  email          String    @unique
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  locationFilter String[]  @default(["台北市", "新北市"])
  school         String?
  department     String?
  grade          String?
  portfolioUrl   String?
  linkedinUrl    String?

  accounts         Account[]
  sessions         Session[]
  resume           Resume?
  jobIntent        JobIntent?
  recommendations  Recommendation[]
  emailLogs        EmailLog[]
  applications     Application[]
  questionBank     QuestionBank[]
  workExperiences  WorkExperience[]
  coachUsages      CoachUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Resume ──────────────────────────────────────────────────────────────────

model Resume {
  id              String    @id @default(cuid())
  userId          String    @unique
  storageUrl      String
  title           String?
  seniority       String?
  industry        String?
  skills          Json      @default("[]")
  yearsExperience Int?
  parsedAt        DateTime?
  updatedAt       DateTime  @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding ResumeEmbedding?
}

model ResumeEmbedding {
  resumeId  String   @id
  embedding Unsupported("vector(768)")
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

// ─── Job Intent ──────────────────────────────────────────────────────────────

model JobIntent {
  id               String   @id @default(cuid())
  userId           String   @unique
  rawInput         String
  expandedKeywords Json     @default("[]")
  roleKeywords     Json     @default("[]") // 角色/職稱關鍵字（爬蟲搜尋 + 候選門票用，避免技能字撈到不同職種）
  updatedAt        DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding IntentEmbedding?
}

model IntentEmbedding {
  intentId  String   @id
  embedding Unsupported("vector(768)")
  updatedAt DateTime @updatedAt

  intent JobIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)
}

// ─── Job Description ─────────────────────────────────────────────────────────

model Jd {
  id                  String    @id @default(cuid())
  source              String    @default("104")
  externalUrl         String    @unique
  companyName         String
  title               String
  skills              Json      @default("[]")
  salaryRange         String?
  seniority           String?
  remote              Boolean   @default(false)
  location            String?
  recruitmentActivity String?
  replyDays           String?
  contactTime         String?
  description         String?
  postedAt            String?
  applicantCount      Int?
  locationFiltered    Boolean   @default(false)
  crawledAt           DateTime  @default(now())
  parseStatus         String    @default("ok")
  delistedAt          DateTime?
  contentHash         String?
  contentUpdatedAt    DateTime?

  embedding        JdEmbedding?
  recommendations  Recommendation[]
  emailLogs        EmailLog[]
  applications     Application[]
}

model JdEmbedding {
  jdId      String @id
  embedding Unsupported("vector(768)")

  jd Jd @relation(fields: [jdId], references: [id], onDelete: Cascade)
}

// ─── Match & Email ───────────────────────────────────────────────────────────

model Recommendation {
  id            String   @id @default(cuid())
  userId        String
  jdId          String
  resumeScore   Float
  intentScore   Float
  finalScore    Float
  reasoning     String?
  alignedSkills Json     @default("[]")
  dailyBatch    DateTime

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jd        Jd         @relation(fields: [jdId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]

  @@unique([userId, jdId, dailyBatch])
}

// ─── Application Tracking ────────────────────────────────────────────────────

model Application {
  id          String   @id @default(cuid())
  userId      String
  jdId        String
  status      String   @default("not_applied")
  companyType  String?
  appliedAt    DateTime?
  scheduledAt  DateTime?
  note        String?
  aiQuestions   Json      @default("[]")
  resumeUrl     String?
  isArchived    Boolean   @default(false)
  archiveReason String?
  archivedAt    DateTime?
  roleCategory  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jd               Jd                @relation(fields: [jdId], references: [id], onDelete: Cascade)
  interviewRecords InterviewRecord[]
  interviewReviews InterviewReview[]

  @@unique([userId, jdId])
}

model InterviewRecord {
  id            String   @id @default(cuid())
  applicationId String
  interviewedAt DateTime
  interviewer   String?
  qa            Json     @default("[]")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}


// ─── Email ───────────────────────────────────────────────────────────────────

model EmailLog {
  id               String    @id @default(cuid())
  userId           String
  recommendationId String
  jdId             String
  sentAt           DateTime  @default(now())
  clickedAt        DateTime?
  trackingToken    String    @unique @default(cuid())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  jd             Jd             @relation(fields: [jdId], references: [id], onDelete: Cascade)
}

// ─── Interview Review ────────────────────────────────────────────────────────

model InterviewReview {
  id              String   @id @default(cuid())
  applicationId   String
  audioUrl        String?
  transcript      String?  @db.Text
  extractedQA     Json     @default("[]")
  overallFeedback String?  @db.Text
  createdAt       DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ─── Work Experience ─────────────────────────────────────────────────────────

model WorkExperience {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("工作") // 工作/實習/專案/社團/競賽/課程 — 同時支援出社會者與學生
  company     String
  role        String
  startDate   String?
  endDate     String?
  description String   @db.Text
  bullets     String[] @default([])
  skills      Json     @default("[]")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Question Bank ───────────────────────────────────────────────────────────

model QuestionBank {
  id                    String   @id @default(cuid())
  userId                String
  question              String
  answer                String?  @db.Text   // deprecated：答案改存 AnswerVersion.content，保留以相容既有復盤寫入
  category              String   @default("other")
  sourceApplicationId   String?
  userPerformance       String?
  roleCategory          String?
  frequency             Int      @default(1)
  isCore                Boolean  @default(false)
  coreKey               String?
  lastAskedCompanies    Json     @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions AnswerVersion[]

  @@unique([userId, coreKey])
}

model AnswerVersion {
  id             String   @id @default(cuid())
  questionBankId String
  label          String   @default("我的版本")
  content        String   @default("") @db.Text
  score          Int?
  grade          String?  // needs_improvement | ok | good
  lastCoaching   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  question QuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
}

// 北極星指標：每週 AI 面試準備使用次數。每次「請教練評估」成功就 append 一筆。
model CoachUsage {
  id        String   @id @default(cuid())
  userId    String
  coreKey   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
